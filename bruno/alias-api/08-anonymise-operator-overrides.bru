meta {
  name: Anonymise (Operator Overrides)
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/anonymise
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "text": "My TFN is 123 456 782 and contact is jane@example.com",
    "operator_overrides": {
      "AU_TFN": "mask",
      "EMAIL_ADDRESS": "hash"
    },
    "refine": true
  }
}
