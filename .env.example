# Copy this file to .env and fill in real values.
# All variables are prefixed with ALIAS_ except provider API keys.

# ── LLM judge (optional) ─────────────────────────────────────────────────────
# Enables two things:
#   1. Accurate mode on POST /detect and POST /anonymise (mode='accurate', default)
#   2. POST /assess — content risk and sensitivity assessment
#
# When unset: mode='accurate' degrades silently to mode='fast'; /assess returns 503.
#
# Built-in providers — use provider:model format:
#   ALIAS_JUDGE_MODEL=anthropic:claude-sonnet-4-6
#   ALIAS_JUDGE_MODEL=openai:gpt-4o
#
# Custom OpenAI-compatible endpoint (Databricks, Azure AI, Ollama, etc.):
#   ALIAS_JUDGE_MODEL=<deployment-name>   # model/deployment name on the endpoint
#   ALIAS_JUDGE_BASE_URL=https://<workspace>.azuredatabricks.net/serving-endpoints
#   ALIAS_JUDGE_API_KEY=<personal-access-token>
ALIAS_JUDGE_MODEL=anthropic:claude-sonnet-4-6
# ALIAS_JUDGE_BASE_URL=
# ALIAS_JUDGE_API_KEY=

# Sampling temperature for the judge (0.0 = deterministic).
ALIAS_JUDGE_TEMPERATURE=0.0

# ── Provider API keys ────────────────────────────────────────────────────────
# Required when ALIAS_JUDGE_MODEL uses the anthropic provider.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required when ALIAS_JUDGE_MODEL uses the openai provider.
# OPENAI_API_KEY=your-openai-api-key-here

# ── spaCy model ──────────────────────────────────────────────────────────────
# en_core_web_sm  — small, fast, used in CI and tests (default)
# en_core_web_lg  — larger, more accurate NER, recommended for production
# Download: uv run python -m spacy download en_core_web_lg
ALIAS_SPACY_MODEL=en_core_web_sm

# ── Server ───────────────────────────────────────────────────────────────────
ALIAS_DEBUG=false

# Thread-pool workers for presidio (CPU-bound). Rule of thumb: number of cores.
ALIAS_EXECUTOR_MAX_WORKERS=4
